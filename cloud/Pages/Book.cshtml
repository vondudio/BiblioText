@page "{id:int}"
@model BookModel
@{
    ViewData["Title"] = Model.Book?.Title ?? "Book";
    var book = Model.Book!;
    var cover = book.CoverImageUrl;
    var spine = book.Copies.Select(c => c.SpineImageUrl).FirstOrDefault(s => !string.IsNullOrEmpty(s));
}

@functions {
    static (double X, double Y, double W, double H)? ParseBox(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return null;
        var p = s.Split(',');
        if (p.Length != 4) return null;
        var ci = System.Globalization.CultureInfo.InvariantCulture;
        const System.Globalization.NumberStyles ns = System.Globalization.NumberStyles.Float;
        if (double.TryParse(p[0], ns, ci, out var x) && double.TryParse(p[1], ns, ci, out var y)
            && double.TryParse(p[2], ns, ci, out var w) && double.TryParse(p[3], ns, ci, out var h))
        {
            return (x, y, w, h);
        }
        return null;
    }

    static string Pct(double v) =>
        (v * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture) + "%";
}

<nav aria-label="breadcrumb" class="mb-3">
    <a asp-page="/Index" class="text-decoration-none">&larr; Back to catalog</a>
</nav>

<div class="row g-4">
    <div class="col-md-4 col-lg-3">
        <div class="book-detail-cover">
            @if (!string.IsNullOrEmpty(cover))
            {
                <img src="@cover" alt="Cover of @book.Title" />
            }
            else if (!string.IsNullOrEmpty(spine))
            {
                <img src="@spine" alt="Spine of @book.Title" class="spine-img" />
            }
            else
            {
                <div class="book-thumb-placeholder large">@book.Title</div>
            }
        </div>
    </div>

    <div class="col-md-8 col-lg-9">
        <h1 class="h2 mb-1">@book.Title</h1>
        @if (!string.IsNullOrEmpty(book.Author))
        {
            <p class="lead text-muted mb-2">@book.Author</p>
        }

        @if (Model.Badges.Count > 0)
        {
            <div class="mb-3">
                @foreach (var badge in Model.Badges)
                {
                    <span class="badge source-badge" title="@badge.Title">@badge.Label</span>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(book.LongDescription))
        {
            <p class="book-description">@book.LongDescription</p>
        }
        else if (!string.IsNullOrEmpty(book.ShortDescription))
        {
            <p class="book-description">@book.ShortDescription</p>
        }
        else
        {
            <p class="text-muted fst-italic">No description available.</p>
        }

        <hr class="my-4" />

        <h2 class="h5 mb-3">Where to find it</h2>
        <div class="list-group">
            @foreach (var copy in book.Copies)
            {
                var box = ParseBox(copy.SpineBoxNorm);
                var whose = string.IsNullOrEmpty(copy.OwnerHousehold) ? "Unknown shelf" : copy.OwnerHousehold;
                <div class="list-group-item">
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(copy.SpineImageUrl))
                        {
                            <img src="@copy.SpineImageUrl" alt="Spine" class="copy-spine" />
                        }
                        <div>
                            <div class="fw-semibold">@whose</div>
                            @if (!string.IsNullOrEmpty(copy.ShelfLocation))
                            {
                                <div class="text-muted small">@copy.ShelfLocation</div>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(copy.BookshelfImageUrl))
                    {
                        <figure class="mt-3 mb-0">
                            <div class="shelf-figure">
                                <img src="@copy.BookshelfImageUrl" alt="@book.Title highlighted on the shelf" loading="lazy" />
                                @if (box is { } b)
                                {
                                    <span class="shelf-box"
                                          style="left:@Pct(b.X);top:@Pct(b.Y);width:@Pct(b.W);height:@Pct(b.H);"></span>
                                }
                            </div>
                            <figcaption class="shelf-caption">
                                @if (box is not null)
                                {
                                    <span>Highlighted on the shelf@(string.IsNullOrEmpty(copy.ShelfLocation) ? "" : $" ({copy.ShelfLocation})").</span>
                                }
                                else
                                {
                                    <span>The shelf this copy lives on@(string.IsNullOrEmpty(copy.ShelfLocation) ? "" : $" ({copy.ShelfLocation})").</span>
                                }
                            </figcaption>
                        </figure>
                    }
                </div>
            }
        </div>
        <p class="text-muted small mt-2">
            To borrow, reach out to the owner directly.
        </p>
    </div>
</div>
