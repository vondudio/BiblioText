@page
@model BiblioText.Cloud.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="text-center mb-4">
            <img src="~/img/flower-bridge.png" alt="Flower Bridge" class="brand-logo mb-3" style="height:96px;" />
            <h1 class="h3">Members sign in</h1>
            <p class="text-muted">Enter your email and we'll send you a one-time sign-in link.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Message))
        {
            <div class="alert @(Model.IsError ? "alert-warning" : "alert-info")" role="alert">
                @Model.Message
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.DevMagicLink))
        {
            <div class="alert alert-success" role="alert">
                <a href="@Model.DevMagicLink" class="fw-bold">Click here to sign in &rarr;</a>
            </div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email address</label>
                <input asp-for="Email" type="email" class="form-control form-control-lg"
                       placeholder="you@example.com" autofocus required />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Send sign-in link</button>
            </div>
        </form>
    </div>
</div>
