<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="BiblioText.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BiblioText"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="BiblioText"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            PaneDisplayMode="Left"
            IsSettingsVisible="True"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Scan" Tag="scan" AutomationProperties.Name="Scan">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE722;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Review" Tag="review" AutomationProperties.Name="Review detected books">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70B;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge
                            x:Name="ReviewPendingBadge"
                            Value="0"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="Book descriptions generating in the background"
                            AutomationProperties.Name="Descriptions pending" />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
                <NavigationViewItem Content="Library" Tag="library" AutomationProperties.Name="Library">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE736;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="RootFrame" Padding="16" />
        </NavigationView>
        <Grid
            x:Name="ProgressRingGrid"
            Background="{ThemeResource SmokeFillColorDefaultBrush}"
            Visibility="Visible">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
                <ProgressRing
                    Width="50"
                    Height="50"
                    IsActive="True"
                    AutomationProperties.Name="Loading BiblioText" />
                <TextBlock
                    Text="Loading BiblioText..."
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
