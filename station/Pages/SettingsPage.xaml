<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BiblioText.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="600">
            <StackPanel Spacing="2" Margin="0,0,0,8">
                <TextBlock
                    Text="Settings"
                    Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock
                    x:Name="VersionText"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.6"
                    AutomationProperties.Name="Application version" />
            </StackPanel>

            <!-- Azure OpenAI Configuration -->
            <StackPanel Spacing="12">
                <TextBlock Text="Azure OpenAI" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Configure your Azure OpenAI endpoint for book title extraction and bookshelf analysis." Opacity="0.7" TextWrapping="Wrap" />

                <TextBox
                    x:Name="EndpointBox"
                    Header="Endpoint"
                    PlaceholderText="https://your-resource.openai.azure.com"
                    AutomationProperties.Name="Azure OpenAI endpoint" />

                <PasswordBox
                    x:Name="ApiKeyBox"
                    Header="API Key"
                    PlaceholderText="Enter your API key"
                    AutomationProperties.Name="Azure OpenAI API key" />

                <TextBox
                    x:Name="DeploymentBox"
                    Header="Deployment Name"
                    PlaceholderText="gpt-4o or your deployment name"
                    AutomationProperties.Name="Azure OpenAI deployment name" />

                <TextBox
                    x:Name="ApiVersionBox"
                    Header="API Version"
                    PlaceholderText="2024-10-21"
                    Text="2024-10-21"
                    AutomationProperties.Name="Azure OpenAI API version" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        x:Name="SaveButton"
                        Content="Save"
                        Click="SaveButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.Name="Save settings" />
                    <Button
                        x:Name="TestButton"
                        Content="Test Connection"
                        Click="TestButton_Click"
                        AutomationProperties.Name="Test Azure OpenAI connection" />
                </StackPanel>

                <InfoBar
                    x:Name="StatusBar"
                    IsOpen="False"
                    IsClosable="True" />
            </StackPanel>

            <!-- Book Metadata Providers -->
            <StackPanel Spacing="12">
                <TextBlock Text="Book Metadata Providers" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock TextWrapping="Wrap" Opacity="0.7"
                    Text="Book descriptions are grounded in real metadata. Google Books supplies publisher-quality descriptions but requires an API key (free from Google Cloud Console). Open Library is used as a fallback and needs no key." />

                <PasswordBox
                    x:Name="GoogleBooksKeyBox"
                    Header="Google Books API Key (optional)"
                    PlaceholderText="Paste your API key from console.cloud.google.com"
                    AutomationProperties.Name="Google Books API key" />
            </StackPanel>

            <!-- Cloud Publishing -->
            <StackPanel Spacing="12">
                <TextBlock Text="Cloud Publishing" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock TextWrapping="Wrap" Opacity="0.7"
                    Text="Publish your reviewed catalog to the BiblioText cloud so it can be searched on the website. Leave the endpoint blank to keep everything local." />

                <TextBox
                    x:Name="CloudEndpointBox"
                    Header="Cloud Endpoint"
                    PlaceholderText="https://your-bibliotext.azurewebsites.net"
                    AutomationProperties.Name="Cloud endpoint URL" />

                <PasswordBox
                    x:Name="CloudOperatorTokenBox"
                    Header="Operator Token"
                    PlaceholderText="Shared publish secret"
                    AutomationProperties.Name="Cloud operator token" />

                <TextBox
                    x:Name="OwnerHouseholdBox"
                    Header="Owner / Household"
                    PlaceholderText="e.g. The Anderson Family"
                    AutomationProperties.Name="Owner or household label" />

                <TextBox
                    x:Name="StationIdBox"
                    Header="Station ID (auto-generated)"
                    IsReadOnly="True"
                    IsTabStop="False"
                    AutomationProperties.Name="Station identifier" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        Content="Save"
                        Click="SaveButton_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.Name="Save cloud settings" />
                    <Button
                        x:Name="TestCloudButton"
                        Content="Test Connection"
                        Click="TestCloudButton_Click"
                        AutomationProperties.Name="Test cloud connection" />
                </StackPanel>

                <InfoBar
                    x:Name="CloudStatusBar"
                    IsOpen="False"
                    IsClosable="True" />
            </StackPanel>

            <!-- Info about env vars -->
            <StackPanel Spacing="8">
                <TextBlock Text="Environment Variable Fallback" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="12"
                    Text="If no settings are saved above, the app will try these environment variables: AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY, AZURE_OPENAI_DEPLOYMENT, AZURE_OPENAI_API_VERSION, GOOGLE_BOOKS_API_KEY, BIBLIOTEXT_CLOUD_ENDPOINT, BIBLIOTEXT_CLOUD_OPERATOR_TOKEN, BIBLIOTEXT_STATION_ID, BIBLIOTEXT_OWNER_HOUSEHOLD" />
            </StackPanel>

            <!-- Camera -->
            <StackPanel Spacing="12">
                <TextBlock Text="Camera" Style="{StaticResource SubtitleTextBlockStyle}" />
                <ToggleSwitch
                    x:Name="UseCameraToggle"
                    Header="Use camera capture"
                    OffContent="Disabled"
                    OnContent="Enabled"
                    Toggled="UseCameraToggle_Toggled"
                    AutomationProperties.Name="Use camera capture" />
            </StackPanel>

            <!-- AI Prompts -->
            <StackPanel Spacing="12">
                <TextBlock Text="AI Prompts" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Customize the prompts sent to Azure OpenAI. Leave blank to use defaults." Opacity="0.7" TextWrapping="Wrap" />

                <TextBox
                    x:Name="SpinePromptBox"
                    Header="Spine Title Extraction"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="240" />

                <TextBox
                    x:Name="BookshelfSystemPromptBox"
                    Header="Bookshelf Analysis — System Prompt"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="240" />

                <TextBox
                    x:Name="BookshelfUserPromptBox"
                    Header="Bookshelf Analysis — User Prompt"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="240" />

                <TextBox
                    x:Name="DescriptionPromptBox"
                    Header="Book Description Generation"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="240" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Update Prompts" Click="SaveButton_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Reset to Defaults" Click="ResetPromptsButton_Click" />
                </StackPanel>
            </StackPanel>

            <!-- Library Data -->
            <StackPanel Spacing="12">
                <TextBlock Text="Library Data" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock
                    Text="Back up your catalog to a .zip archive (database, spine crops, and bookshelf photos), or wipe the library to start fresh. Your Azure / Google Books keys and prompt settings are never touched by either action."
                    Opacity="0.7"
                    TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        x:Name="ExportLibraryButton"
                        Content="Export to .zip…"
                        Click="ExportLibraryButton_Click"
                        AutomationProperties.Name="Export library to a zip archive" />
                    <Button
                        x:Name="ResetLibraryButton"
                        Content="Reset Library…"
                        Click="ResetLibraryButton_Click"
                        AutomationProperties.Name="Reset library and delete all books" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
