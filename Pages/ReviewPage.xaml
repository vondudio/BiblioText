<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="AIDevGallery.Sample.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Text="Review Detected Books"
            Style="{StaticResource TitleTextBlockStyle}"
            Margin="0,0,0,8" />

        <!-- Source image thumbnail -->
        <Border
            x:Name="SourceImageBorder"
            Grid.Row="1"
            Width="120"
            Height="80"
            HorizontalAlignment="Left"
            Margin="0,0,0,8"
            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
            CornerRadius="4"
            Visibility="Collapsed"
            PointerPressed="SourceImage_Click"
            ToolTipService.ToolTip="Click to view full image">
            <Image x:Name="SourceThumbnail" Stretch="UniformToFill" />
        </Border>

        <TextBlock
            Grid.Row="2"
            x:Name="ReviewStatus"
            Text="No scan results to review. Run a scan first from the Scan tab."
            Opacity="0.7"
            Margin="0,0,0,16" />

        <!-- Book list -->
        <ListView
            x:Name="ReviewList"
            Grid.Row="3"
            SelectionMode="None"
            Visibility="Collapsed"
            ContainerContentChanging="ReviewList_ContainerContentChanging">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Crop thumbnail (click to view) -->
                        <Border
                            Grid.Column="0"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="4"
                            Height="100"
                            PointerPressed="CropThumbnail_PointerPressed"
                            ToolTipService.ToolTip="Click to view spine crop">
                            <Image x:Name="CropImage" Stretch="Uniform" />
                        </Border>

                        <!-- Editable fields -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock
                                Text="{Binding DisplayLabel}"
                                FontSize="11"
                                Opacity="0.5"
                                FontFamily="Consolas" />
                            <TextBox
                                Header="Title"
                                Text="{Binding EditedTitle, Mode=TwoWay}"
                                PlaceholderText="Book title" />
                            <TextBox
                                Header="Author"
                                Text="{Binding EditedAuthor, Mode=TwoWay}"
                                PlaceholderText="Author (optional)" />
                        </StackPanel>

                        <!-- Accept/Reject toggle -->
                        <ToggleSwitch
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            IsOn="{Binding IsAccepted, Mode=TwoWay}"
                            OnContent="Accept"
                            OffContent="Reject" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Actions -->
        <Grid
            Grid.Row="4"
            Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Location selector -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Location:" VerticalAlignment="Center" Opacity="0.8" />
                <ComboBox
                    x:Name="LocationDropdown"
                    MinWidth="200"
                    PlaceholderText="Select location..."
                    DisplayMemberPath="Name" />
                <Button
                    x:Name="AddLocationButton"
                    Click="AddLocationButton_Click"
                    ToolTipService.ToolTip="Add new location"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="12" />
                </Button>
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="12">
                <Button Content="Accept All" x:Name="AcceptAllButton" Click="AcceptAllButton_Click" />
                <Button Content="Reject All" x:Name="RejectAllButton" Click="RejectAllButton_Click" />
                <Button
                    Content="Save to Library"
                    x:Name="SaveButton"
                    Click="SaveButton_Click"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- Fullscreen image overlay -->
        <Grid
            x:Name="ImageOverlay"
            Grid.Row="0"
            Grid.RowSpan="99"
            Background="{ThemeResource SmokeFillColorDefaultBrush}"
            Visibility="Collapsed"
            PointerPressed="ImageOverlay_PointerPressed">
            <ScrollViewer
                x:Name="OverlayScroller"
                ZoomMode="Enabled"
                MinZoomFactor="1.0"
                MaxZoomFactor="3.0"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollMode="Auto"
                VerticalScrollMode="Auto"
                DoubleTapped="OverlayScroller_DoubleTapped">
                <Viewbox
                    Stretch="Uniform"
                    Width="{Binding ViewportWidth, ElementName=OverlayScroller}"
                    Height="{Binding ViewportHeight, ElementName=OverlayScroller}">
                    <Image x:Name="OverlayImage" />
                </Viewbox>
            </ScrollViewer>
            <Button
                Content="✕"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="16"
                Click="CloseOverlay_Click"
                FontSize="20"
                Width="40"
                Height="40" />
        </Grid>
    </Grid>
</Page>
