<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BiblioText.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with scan navigation -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Review Detected Books"
                Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Scan set navigation -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8"
                x:Name="ScanNavPanel"
                Visibility="Collapsed">
                <Button
                    x:Name="PrevScanButton"
                    Click="PrevScanButton_Click"
                    ToolTipService.ToolTip="Previous scan"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76B;" FontSize="14" />
                </Button>
                <TextBlock
                    x:Name="ScanIndexLabel"
                    VerticalAlignment="Center"
                    Text="1 / 1"
                    Opacity="0.7" />
                <Button
                    x:Name="NextScanButton"
                    Click="NextScanButton_Click"
                    ToolTipService.ToolTip="Next scan"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock
            Grid.Row="1"
            x:Name="ReviewStatus"
            Text="No scan results to review. Run a scan first from the Scan tab."
            Opacity="0.7"
            Margin="0,0,0,12" />

        <!-- Main content: two-column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="ImagePanelColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <!-- Left: Book list (editable) -->
            <ListView
                x:Name="ReviewList"
                Grid.Column="0"
                SelectionMode="None"
                Visibility="Collapsed"
                ContainerContentChanging="ReviewList_ContainerContentChanging">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Crop thumbnail (click to view in right panel) -->
                            <Border
                                Grid.Column="0"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="4"
                                Width="80"
                                VerticalAlignment="Stretch"
                                PointerPressed="CropThumbnail_PointerPressed"
                                ToolTipService.ToolTip="Click to view spine crop">
                                <Image x:Name="CropImage" Stretch="Uniform" />
                            </Border>

                            <!-- Editable fields -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <TextBlock
                                    Text="{Binding DisplayLabel}"
                                    FontSize="11"
                                    Opacity="0.5"
                                    FontFamily="Consolas" />
                                <Grid>
                                    <TextBox
                                        Header="Title"
                                        Text="{Binding EditedTitle, Mode=TwoWay}"
                                        PlaceholderText="Book title"
                                        Padding="8,8,32,8" />
                                    <Button
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Padding="4"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="MicButton_Click"
                                        Tag="Title"
                                        ToolTipService.ToolTip="Record voice (up to 10s)">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="14" />
                                    </Button>
                                </Grid>
                                <Grid>
                                    <TextBox
                                        Header="Author"
                                        Text="{Binding EditedAuthor, Mode=TwoWay}"
                                        PlaceholderText="Author (optional)"
                                        Padding="8,8,32,8" />
                                    <Button
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Padding="4"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="MicButton_Click"
                                        Tag="Author"
                                        ToolTipService.ToolTip="Record voice (up to 10s)">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Accept/Reject toggle -->
                            <ToggleSwitch
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                IsOn="{Binding IsAccepted, Mode=TwoWay}"
                                OnContent="Accept"
                                OffContent="Reject" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Right: Floating image panel -->
            <Grid
                x:Name="ImagePanel"
                Grid.Column="1"
                Visibility="Collapsed"
                Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button
                    Grid.Row="0"
                    Content="✕"
                    HorizontalAlignment="Right"
                    Click="CloseImagePanel_Click"
                    Padding="8,4"
                    Margin="0,0,0,8"
                    ToolTipService.ToolTip="Close image" />

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <ScrollViewer
                        x:Name="ImagePanelScroller"
                        ZoomMode="Enabled"
                        MinZoomFactor="1.0"
                        MaxZoomFactor="5.0"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollMode="Enabled">
                        <Viewbox Stretch="Uniform"
                                 Width="{Binding ViewportWidth, ElementName=ImagePanelScroller}"
                                 Height="{Binding ViewportHeight, ElementName=ImagePanelScroller}">
                            <Image
                                x:Name="ImagePanelImage"
                                Stretch="Uniform" />
                        </Viewbox>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Actions -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Location selector -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Location:" VerticalAlignment="Center" Opacity="0.8" />
                <ComboBox
                    x:Name="LocationDropdown"
                    MinWidth="200"
                    PlaceholderText="Select location..."
                    DisplayMemberPath="Name" />
                <Button
                    x:Name="AddLocationButton"
                    Click="AddLocationButton_Click"
                    ToolTipService.ToolTip="Add new location"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="12" />
                </Button>
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="12">
                <Button Content="Cancel Import" x:Name="CancelButton" Click="CancelButton_Click"
                        Visibility="Collapsed" />
                <Button Content="Accept All" x:Name="AcceptAllButton" Click="AcceptAllButton_Click" />
                <Button Content="Reject All" x:Name="RejectAllButton" Click="RejectAllButton_Click" />
                <Button
                    Content="Save to Library"
                    x:Name="SaveButton"
                    Click="SaveButton_Click"
                    Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>

        <!-- Slim status bar (row 4) -->
        <Border
            Grid.Row="4"
            x:Name="ReviewStatusBar"
            Padding="12,4"
            Margin="0,8,0,0"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="4">
            <TextBlock
                x:Name="ReviewStatusText"
                FontSize="12"
                Opacity="0.8"
                Text="Ready" />
        </Border>
    </Grid>
</Page>
