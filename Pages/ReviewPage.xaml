<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BiblioText.Pages.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with scan navigation -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Review Detected Books"
                Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Scan set navigation -->
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="8"
                x:Name="ScanNavPanel"
                Visibility="Collapsed">
                <Button
                    x:Name="PrevScanButton"
                    Click="PrevScanButton_Click"
                    ToolTipService.ToolTip="Previous scan"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76B;" FontSize="14" />
                </Button>
                <TextBlock
                    x:Name="ScanIndexLabel"
                    VerticalAlignment="Center"
                    Text="1 / 1"
                    Opacity="0.7" />
                <Button
                    x:Name="NextScanButton"
                    Click="NextScanButton_Click"
                    ToolTipService.ToolTip="Next scan"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock
            Grid.Row="1"
            x:Name="ReviewStatus"
            Text="No scan results to review. Run a scan first from the Scan tab."
            Opacity="0.7"
            Margin="0,0,0,12" />

        <!-- Main content: two-column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Book list (editable) -->
            <ListView
                x:Name="ReviewList"
                Grid.Column="0"
                SelectionMode="Multiple"
                SelectionChanged="ReviewList_SelectionChanged"
                Visibility="Collapsed"
                ContainerContentChanging="ReviewList_ContainerContentChanging">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Crop thumbnail (Library-style button with image) -->
                            <Button
                                Grid.Column="0"
                                Width="64"
                                Height="84"
                                Padding="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="CropThumbnail_Click"
                                ToolTipService.ToolTip="View spine crop">
                                <Border
                                    Width="64"
                                    Height="84"
                                    CornerRadius="4"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <Grid>
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe MDL2 Assets"
                                            Glyph="&#xE736;"
                                            FontSize="20"
                                            Opacity="0.3" />
                                        <Image x:Name="CropImage" Stretch="UniformToFill" />
                                        <Border
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="0,0,4,0"
                                            Padding="3,1">
                                            <TextBlock Text="{Binding DisplayLabel}" FontSize="9" Foreground="White" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>

                            <!-- Editable fields -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <Grid>
                                    <TextBox
                                        Header="Title"
                                        Text="{Binding EditedTitle, Mode=TwoWay}"
                                        PlaceholderText="Book title"
                                        Padding="8,8,32,8" />
                                    <Button
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Padding="4"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="MicButton_Click"
                                        Tag="Title"
                                        ToolTipService.ToolTip="Record voice (up to 10s)">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="14" />
                                    </Button>
                                </Grid>
                                <Grid>
                                    <TextBox
                                        Header="Author"
                                        Text="{Binding EditedAuthor, Mode=TwoWay}"
                                        PlaceholderText="Author (optional)"
                                        Padding="8,8,32,8" />
                                    <Button
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0,0,4,4"
                                        Padding="4"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="MicButton_Click"
                                        Tag="Author"
                                        ToolTipService.ToolTip="Record voice (up to 10s)">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Right: Bookspine image panel (1/3 screen) -->
            <Border
                Grid.Column="1"
                Margin="12,0,0,0"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                CornerRadius="8">
                <ScrollViewer
                    x:Name="SpineOverlayScroller"
                    ZoomMode="Enabled"
                    MinZoomFactor="1.0"
                    MaxZoomFactor="5.0"
                    HorizontalScrollBarVisibility="Hidden"
                    VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollMode="Enabled">
                    <Image
                        x:Name="SpineOverlayImage"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Actions -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Location selector -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Location:" VerticalAlignment="Center" Opacity="0.8" />
                <ComboBox
                    x:Name="LocationDropdown"
                    MinWidth="200"
                    PlaceholderText="Select location..."
                    DisplayMemberPath="Name" />
                <Button
                    x:Name="AddLocationButton"
                    Click="AddLocationButton_Click"
                    ToolTipService.ToolTip="Add new location"
                    Padding="6,4">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="12" />
                </Button>
            </StackPanel>

            <!-- Action buttons -->
            <StackPanel
                Grid.Column="2"
                Orientation="Horizontal"
                Spacing="12">
                <Button Content="Cancel Import" x:Name="CancelButton" Click="CancelButton_Click"
                        Visibility="Collapsed" />
                <Button x:Name="DeleteSelectedButton" Click="DeleteSelectedButton_Click" IsEnabled="False"
                        ToolTipService.ToolTip="Delete selected books from review">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="14" />
                        <TextBlock Text="Delete" />
                    </StackPanel>
                </Button>
                <Button
                    x:Name="SendToLibraryButton"
                    Click="SendToLibraryButton_Click"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Save selected books to library">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE736;" FontSize="14" />
                        <TextBlock Text="Send to Library" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Slim status bar (row 4) -->
        <Border
            Grid.Row="4"
            x:Name="ReviewStatusBar"
            Padding="12,4"
            Margin="0,8,0,0"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            CornerRadius="4">
            <TextBlock
                x:Name="ReviewStatusText"
                FontSize="12"
                Opacity="0.8"
                Text="Ready" />
        </Border>
    </Grid>
</Page>
