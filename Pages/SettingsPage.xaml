<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BiblioText.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="600">
            <TextBlock
                Text="Settings"
                Style="{StaticResource TitleTextBlockStyle}"
                Margin="0,0,0,8" />

            <!-- Azure OpenAI Configuration -->
            <StackPanel Spacing="12">
                <TextBlock Text="Azure OpenAI" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Configure your Azure OpenAI endpoint for book title extraction and bookshelf analysis." Opacity="0.7" TextWrapping="Wrap" />

                <TextBox
                    x:Name="EndpointBox"
                    Header="Endpoint"
                    PlaceholderText="https://your-resource.openai.azure.com" />

                <PasswordBox
                    x:Name="ApiKeyBox"
                    Header="API Key"
                    PlaceholderText="Enter your API key" />

                <TextBox
                    x:Name="DeploymentBox"
                    Header="Deployment Name"
                    PlaceholderText="gpt-4o or your deployment name" />

                <TextBox
                    x:Name="ApiVersionBox"
                    Header="API Version"
                    PlaceholderText="2024-10-21"
                    Text="2024-10-21" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button
                        x:Name="SaveButton"
                        Content="Save"
                        Click="SaveButton_Click"
                        Style="{StaticResource AccentButtonStyle}" />
                    <Button
                        x:Name="TestButton"
                        Content="Test Connection"
                        Click="TestButton_Click" />
                </StackPanel>

                <InfoBar
                    x:Name="StatusBar"
                    IsOpen="False"
                    IsClosable="True" />
            </StackPanel>

            <!-- Info about env vars -->
            <StackPanel Spacing="8">
                <TextBlock Text="Environment Variable Fallback" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock TextWrapping="Wrap" Opacity="0.6" FontSize="12"
                    Text="If no settings are saved above, the app will try these environment variables: AZURE_OPENAI_ENDPOINT, AZURE_OPENAI_API_KEY, AZURE_OPENAI_DEPLOYMENT, AZURE_OPENAI_API_VERSION" />
            </StackPanel>

            <!-- Camera -->
            <StackPanel Spacing="12">
                <TextBlock Text="Camera" Style="{StaticResource SubtitleTextBlockStyle}" />
                <ToggleSwitch
                    x:Name="UseCameraToggle"
                    Header="Use camera capture"
                    OffContent="Disabled"
                    OnContent="Enabled"
                    Toggled="UseCameraToggle_Toggled" />
            </StackPanel>

            <!-- AI Prompts -->
            <StackPanel Spacing="12">
                <TextBlock Text="AI Prompts" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Customize the prompts sent to Azure OpenAI. Leave blank to use defaults." Opacity="0.7" TextWrapping="Wrap" />

                <TextBox
                    x:Name="SpinePromptBox"
                    Header="Spine Title Extraction"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="120" />

                <TextBox
                    x:Name="BookshelfSystemPromptBox"
                    Header="Bookshelf Analysis — System Prompt"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="120" />

                <TextBox
                    x:Name="BookshelfUserPromptBox"
                    Header="Bookshelf Analysis — User Prompt"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="120" />

                <TextBox
                    x:Name="DescriptionPromptBox"
                    Header="Book Description Generation"
                    PlaceholderText="(default prompt)"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="120" />

                <Button Content="Reset Prompts to Defaults" Click="ResetPromptsButton_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
